{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Direkta",
  "version": "1.0.0",
  "description": "Playful retro modern — cream / tomato / mustard / viridian / cocoa, Bagel Fat One display, soft shadows, 16px radius, slight tilt.",
  "color": {
    "core": {
      "cream":         { "value": "#F5EDDC", "type": "color" },
      "cream-warm":    { "value": "#FFFBF1", "type": "color" },
      "cream-deep":    { "value": "#EAD8B5", "type": "color" },
      "cocoa":         { "value": "#2A1A12", "type": "color" },
      "cocoa-soft":    { "value": "#4A382C", "type": "color" },
      "cocoa-mute":    { "value": "#7A6855", "type": "color" },
      "tomato":        { "value": "#E84A35", "type": "color" },
      "tomato-deep":   { "value": "#B6321F", "type": "color" },
      "mustard":       { "value": "#F2B83C", "type": "color" },
      "mustard-deep":  { "value": "#C7901C", "type": "color" },
      "viridian":      { "value": "#3DA89B", "type": "color" },
      "viridian-deep": { "value": "#26786E", "type": "color" }
    },
    "semantic": {
      "bg":       { "value": "{color.core.cream}",      "type": "color" },
      "surface":  { "value": "{color.core.cream-warm}", "type": "color" },
      "surface-2":{ "value": "{color.core.cream-deep}", "type": "color" },
      "ink":      { "value": "{color.core.cocoa}",      "type": "color" },
      "mute":     { "value": "{color.core.cocoa-mute}", "type": "color" },
      "accent":   { "value": "{color.core.tomato}",     "type": "color" },
      "accent-2": { "value": "{color.core.mustard}",    "type": "color" },
      "accent-3": { "value": "{color.core.viridian}",   "type": "color" },
      "success":  { "value": "{color.core.viridian}",   "type": "color" },
      "warning":  { "value": "{color.core.mustard}",    "type": "color" },
      "danger":   { "value": "{color.core.tomato}",     "type": "color" }
    }
  },
  "typography": {
    "family": {
      "display": { "value": "\"Bagel Fat One\", \"Lilita One\", \"Alfa Slab One\", Impact, serif", "type": "fontFamily" },
      "ui":      { "value": "\"Nunito\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", system-ui, sans-serif", "type": "fontFamily" },
      "mono":    { "value": "\"JetBrains Mono\", ui-monospace, \"SFMono-Regular\", Menlo, monospace", "type": "fontFamily" }
    },
    "size": {
      "display-l": { "value": "96px", "type": "dimension" },
      "display-m": { "value": "64px", "type": "dimension" },
      "h1":        { "value": "48px", "type": "dimension" },
      "h2":        { "value": "28px", "type": "dimension" },
      "h3":        { "value": "22px", "type": "dimension" },
      "h4":        { "value": "18px", "type": "dimension" },
      "body-l":    { "value": "17px", "type": "dimension" },
      "body":      { "value": "15px", "type": "dimension" },
      "body-s":    { "value": "13px", "type": "dimension" },
      "cap":       { "value": "11px", "type": "dimension" },
      "eyebrow":   { "value": "10px", "type": "dimension" }
    },
    "leading": {
      "tight": { "value": "1.05", "type": "number" },
      "snug":  { "value": "1.25", "type": "number" },
      "body":  { "value": "1.5",  "type": "number" }
    },
    "tracking": {
      "display": { "value": "0.01em", "type": "dimension" },
      "eyebrow": { "value": "0.22em", "type": "dimension" },
      "mono":    { "value": "0.06em", "type": "dimension" }
    }
  },
  "radius": {
    "sm":   { "value": "8px",   "type": "dimension" },
    "md":   { "value": "16px",  "type": "dimension" },
    "lg":   { "value": "24px",  "type": "dimension" },
    "pill": { "value": "999px", "type": "dimension" }
  },
  "spacing": {
    "1": { "value": "4px",  "type": "dimension" },
    "2": { "value": "8px",  "type": "dimension" },
    "3": { "value": "12px", "type": "dimension" },
    "4": { "value": "16px", "type": "dimension" },
    "5": { "value": "24px", "type": "dimension" },
    "6": { "value": "32px", "type": "dimension" },
    "7": { "value": "48px", "type": "dimension" },
    "8": { "value": "64px", "type": "dimension" },
    "9": { "value": "96px", "type": "dimension" }
  },
  "shadow": {
    "1":     { "value": "0 2px 6px rgba(42,26,18,0.06), 0 1px 2px rgba(42,26,18,0.04)",   "type": "shadow" },
    "2":     { "value": "0 6px 14px rgba(42,26,18,0.10), 0 2px 4px rgba(42,26,18,0.06)",  "type": "shadow" },
    "3":     { "value": "0 14px 32px rgba(42,26,18,0.14), 0 4px 8px rgba(42,26,18,0.08)", "type": "shadow" },
    "focus": { "value": "0 0 0 3px rgba(232,74,53,0.30)", "type": "shadow" }
  },
  "motion": {
    "dur": {
      "1": { "value": "120ms", "type": "duration" },
      "2": { "value": "220ms", "type": "duration" },
      "3": { "value": "360ms", "type": "duration" },
      "4": { "value": "520ms", "type": "duration" }
    },
    "ease": {
      "out":    { "value": "cubic-bezier(0.22, 0.61, 0.36, 1)",  "type": "cubicBezier" },
      "in":     { "value": "cubic-bezier(0.55, 0.06, 0.68, 0.19)","type": "cubicBezier" },
      "spring": { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)",   "type": "cubicBezier" }
    }
  },
  "tilt": {
    "card-a": { "value": "-0.6deg", "type": "rotation" },
    "card-b": { "value": "0.5deg",  "type": "rotation" },
    "card-c": { "value": "-0.3deg", "type": "rotation" }
  }
}
